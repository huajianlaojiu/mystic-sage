# === Supabase ===
# 去 https://supabase.com 注册 → 建 project → 拿到下面两个值
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# === OpenAI ===
# 去 https://platform.openai.com/api-keys 拿 key
# 如果在国内用香港代理转发，改 BASE_URL
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com

# === Lemon Squeezy ===
# 去 https://lemonsqueezy.com 注册 → Settings → API Keys
LEMONSQUEEZY_API_KEY=your-lemon-api-key
LEMONSQUEEZY_STORE_ID=your-store-id
LEMONSQUEEZY_WEBHOOK_SECRET=your-webhook-secret

# 在 Lemon Squeezy 后台创建产品后，把 variant ID 填到这里
LS_VARIANT_PLUS_MONTHLY=
LS_VARIANT_PLUS_ANNUAL=
LS_VARIANT_PREMIUM_MONTHLY=
LS_VARIANT_PREMIUM_ANNUAL=
LS_VARIANT_BIRTH_CHART=
LS_VARIANT_ANNUAL_FORECAST=
LS_VARIANT_COUPLES_COMPAT=
